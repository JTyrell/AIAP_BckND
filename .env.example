# ── AIAP Backend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in values for your deployment.

# Flask
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# Database — set DB_AVAILABLE=true once PostgreSQL is connected
DATABASE_URL=postgresql://user:password@localhost:5432/aiap_db
DB_AVAILABLE=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth credentials (override defaults)
OPS_USERNAME=ops.admin
OPS_PASSWORD=aiap2026
CUSTOMER_USERNAME=customer
CUSTOMER_PASSWORD=uwiatm

# Synthetic Supervisor noise parameters
NOISE_SIGMA_HEALTH=2.5
NOISE_SIGMA_CASH=0.5
LABEL_FLIP_RATE=0.02
